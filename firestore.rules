rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users' shopping lists: only owner can read/write
    match /users/{userId}/shopping_lists/{listId} {
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['title', 'itemsCount', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.itemsCount is int;

      allow read, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // Deny access to any other documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
